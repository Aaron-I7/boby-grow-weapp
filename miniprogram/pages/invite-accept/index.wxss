.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.content {
  padding: 24rpx 0 calc(40rpx + env(safe-area-inset-bottom));
}

.hero {
  background: linear-gradient(135deg, #0a7fb3 0%, #59bbe3 100%);
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.92);
}

.loading {
  padding: 80rpx 0;
  text-align: center;
  color: #7c8996;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #edf2f6;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 24rpx;
  color: #72808d;
}

.value {
  font-size: 26rpx;
  color: #22303a;
  text-align: right;
}

.status-error {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #c73939;
  text-align: center;
}

.actions {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.btn-outline {
  height: 84rpx;
  border-radius: 42rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff;
  color: #0f6f92;
  border: 2rpx solid #0f6f92;
}
