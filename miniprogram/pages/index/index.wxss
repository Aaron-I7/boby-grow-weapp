.container {
  justify-content: center;
}

.card {
  margin-top: 120rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 18rpx rgba(20, 30, 40, 0.06);
}

.title {
  display: block;
  font-size: 36rpx;
  color: #1f2a33;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #7b8691;
}

.btn {
  margin-top: 24rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #0f6f92;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}
