page { background: #FFF8E1; }
.child-container { padding: 0 32rpx 60rpx; background: #FFF8E1; min-height: 100vh; }

.form-label { font-size: 30rpx; font-weight: 700; color: #5D4037; display: block; margin-bottom: 16rpx; margin-top: 32rpx; }
.form-input { background: #fff; border-radius: 24rpx; padding: 28rpx; font-size: 30rpx; color: #5D4037; box-shadow: 0 4rpx 16rpx rgba(255,152,0,0.08); }

.icon-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.icon-item { width: 88rpx; height: 88rpx; border-radius: 24rpx; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 40rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.icon-selected { border: 4rpx solid #FF9800; background: #FFF3E0; }

.submit-btn { margin-top: 48rpx; background: #FF9800; border-radius: 48rpx; height: 96rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 34rpx; font-weight: 800; box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.3); }

.hint { text-align: center; font-size: 24rpx; color: #999; margin-top: 24rpx; }
