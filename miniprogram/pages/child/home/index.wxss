page { background: #FFF8E1; }

.child-container { padding: 0 32rpx 60rpx; background: #FFF8E1; min-height: 100vh; }

.child-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 0; }
.child-header-left { display: flex; align-items: center; gap: 20rpx; }
.child-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  display: block;
  border: 6rpx solid #FF9800;
  box-sizing: border-box;
}
.child-greeting { display: flex; flex-direction: column; }
.child-name { font-size: 40rpx; font-weight: 800; color: #5D4037; }
.child-sub { font-size: 28rpx; color: #FF9800; font-weight: 600; }

.points-hero { background: linear-gradient(135deg, #FF9800, #FFB74D); border-radius: 48rpx; padding: 60rpx 40rpx; text-align: center; color: #fff; margin-bottom: 40rpx; position: relative; overflow: hidden; }
.points-hero-label { font-size: 28rpx; opacity: 0.9; letter-spacing: 4rpx; }
.points-hero-row { display: flex; align-items: baseline; justify-content: center; gap: 12rpx; margin-top: 8rpx; }
.points-hero-num { font-size: 120rpx; font-weight: 900; }
.points-hero-star-img { width: 60rpx; height: 60rpx; }
.star-deco { position: absolute; }

.task-section-title { font-size: 40rpx; font-weight: 800; color: #5D4037; margin-bottom: 24rpx; }
.task-remain { background: rgba(124,87,22,0.1); color: #5D4037; padding: 6rpx 20rpx; border-radius: 24rpx; font-size: 24rpx; font-weight: 600; }

.child-task-card { background: #fff; border-radius: 40rpx; padding: 32rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 24rpx; box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.1); border-bottom: 8rpx solid #f5f5f5; }
.child-task-card.completed { opacity: 0.7; }
.task-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; }
.task-icon-label { font-size: 32rpx; font-weight: 800; }
.task-icon-green { background: #E8F5E9; }
.task-icon-blue { background: #E1F5FE; }
.task-icon-orange { background: #FFF3E0; }
.task-icon-purple { background: #F3E5F5; }
.child-task-info { flex: 1; }
.child-task-name { font-size: 32rpx; font-weight: 800; color: #5D4037; display: block; }
.child-task-status { font-size: 26rpx; font-weight: 600; }
.child-task-status.done { color: #4CAF50; }
.child-task-status.pending { color: #999; }
.task-check { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #fff; }
.task-check-done { background: #4CAF50; }
.task-check-pending { background: #FF9800; }

.shortcut-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-top: 40rpx; }
.shortcut-card { border-radius: 40rpx; padding: 32rpx; display: flex; flex-direction: column; align-items: center; gap: 12rpx; border-bottom: 8rpx solid transparent; }
.shortcut-orange { background: #FFEDD5; border-bottom-color: #FED7AA; }
.shortcut-blue { background: #E0F2FE; border-bottom-color: #BAE6FD; }
.shortcut-purple { background: #F5F3FF; border-bottom-color: #DDD6FE; }
.shortcut-icon { width: 80rpx; height: 80rpx; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.shortcut-icon-text { font-size: 30rpx; font-weight: 800; color: #5D4037; }
.shortcut-text { font-size: 28rpx; font-weight: 800; color: #5D4037; }

.wish-btn { margin-top: 40rpx; background: #FF9800; border-radius: 48rpx; height: 100rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 36rpx; font-weight: 800; box-shadow: 0 8rpx 24rpx rgba(255,152,0,0.3); border-bottom: 8rpx solid #E67E00; }

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-card {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5D4037;
}

.modal-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8A7D73;
  line-height: 1.6;
}

.modal-input {
  margin-top: 20rpx;
  min-height: 160rpx;
  background: #FFF8E1;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #5D4037;
}

.modal-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.modal-btn.cancel {
  background: #F2EFE9;
  color: #6B5A4C;
}

.modal-btn.confirm {
  background: #FF9800;
  color: #fff;
}

.phrase-row {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.phrase-chip {
  background: #FFF1D6;
  color: #8A5A00;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  line-height: 1.3;
}

.wish-drawer {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 30rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
}

.wish-drawer-head {
  margin-bottom: 16rpx;
}

.wish-drawer-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #5D4037;
}

.wish-drawer-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8A7D73;
}

.wish-input {
  width: 100%;
  height: 84rpx;
  border-radius: 16rpx;
  background: #FFF8E1;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #5D4037;
}

.wish-icon-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.wish-icon-item {
  height: 88rpx;
  border-radius: 16rpx;
  background: #FFF8E1;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.wish-icon-item-active {
  border-color: #FF9800;
  background: #FFE7BF;
}

.wish-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.wish-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.wish-btn-cancel,
.wish-btn-confirm {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.wish-btn-cancel {
  background: #F2EFE9;
  color: #6B5A4C;
}

.wish-btn-confirm {
  background: #FF9800;
  color: #fff;
}
