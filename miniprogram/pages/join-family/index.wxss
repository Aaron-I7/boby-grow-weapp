.invite-card {
  text-align: center;
  padding: 48rpx;
  margin-top: 40rpx;
}

.invite-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e1f5fe;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.invite-title {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 8rpx;
}

.invite-desc {
  font-size: 26rpx;
  color: #6f7b87;
}

.form-card {
  margin-top: 24rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.nick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.nick-item {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f7fa;
  font-size: 26rpx;
  color: #66737f;
}

.nick-active {
  background: #006688;
  color: #fff;
}
