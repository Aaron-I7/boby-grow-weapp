.container {
  min-height: 100vh;
  background: var(--parent-bg);
}

.nav-shell {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(248, 249, 251, 0.94);
  backdrop-filter: blur(8rpx);
  border-bottom: 1rpx solid var(--parent-border);
}

.nav-inner {
  height: 100%;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 10rpx 6rpx 0;
  border-radius: 20rpx;
}

.nav-back {
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  font-size: 34rpx;
  color: var(--parent-primary-strong);
  font-weight: 700;
}

.nav-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx solid #b8dff0;
}

.body {
  padding: 38rpx 0 calc(198rpx + env(safe-area-inset-bottom));
}

.form-stack {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-top: 60rpx;
}

.form-item.no-margin {
  margin-bottom: 0;
}

.form-name .form-input {
  border-radius: 22rpx;
}

.mode-switch-row {
  margin-top: 26rpx;
  display: flex;
  gap: 14rpx;
}

.mode-switch-item {
  flex: 1 1 0;
  height: 76rpx;
  border-radius: 18rpx;
  background: #e9edf3;
  color: #5c6772;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.mode-switch-item-active {
  background: var(--parent-primary);
  color: var(--parent-surface);
}

.form-label {
  display: block;
  margin-bottom: 20rpx;
  font-size: 20rpx;
  color: var(--parent-text-hint);
  font-weight: 700;
}

.form-input {
  width: 100%;
  border-radius: 16rpx;
  background: var(--parent-surface-muted);
  padding: 18rpx 20rpx;
  font-size: 34rpx;
  line-height: 1.3;
  color: #26323c;
}

.purpose-input {
  min-height: 140rpx;
  height: 140rpx;
  box-sizing: border-box;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-column-gap: 40rpx;
  grid-row-gap: 18rpx;
}

.cat-item {
  height: 80rpx;
  border-radius: 18rpx;
  background: var(--parent-surface-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-active {
  background: var(--parent-primary);
}

.cat-icon {
  width: 45rpx;
  height: 45rpx;
  margin-right: 16rpx;
}

.cat-text {
  font-size: 30rpx;
  color: #36414a;
  font-weight: 600;
}

.cat-active .cat-text {
  color: var(--parent-surface);
}

.custom-category-editor {
  margin-top: 14rpx;
  background: #eef1f4;
  border-radius: 16rpx;
  padding: 14rpx;
}

.custom-category-input {
  width: 100%;
  background: var(--parent-surface);
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
  font-size: 26rpx;
  color: #293541;
}

.custom-category-tip {
  display: block;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #6d7882;
}

.custom-icon-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.custom-icon-item {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: var(--parent-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.custom-icon-active {
  border-color: var(--parent-primary);
  background: #dff0f7;
}

.custom-icon-img {
  width: 30rpx;
  height: 30rpx;
}

.points-row {
  display: flex;
  gap: 14rpx;
  row-gap: 14rpx;
  flex-wrap: wrap;
  align-items: center;
}

.reward-block {
  background: var(--parent-surface-muted);
  border-radius: 26rpx;
  padding: 22rpx 20rpx 20rpx;
  position: relative;
  overflow: hidden;
  margin-top: 30rpx;
}

.reward-block::after {
  content: '';
  position: absolute;
  right: -34rpx;
  top: -34rpx;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(15, 111, 146, 0.08);
}

.reward-block .form-label {
  position: relative;
  z-index: 1;
}

.reward-block .points-row {
  position: relative;
  z-index: 1;
}

.pt-item {
  min-width: 98rpx;
  padding: 16rpx 14rpx;
  text-align: center;
  border-radius: 16rpx;
  background: var(--parent-surface);
  color: var(--parent-text-secondary);
  font-size: 30rpx;
  font-weight: 600;
}

.pt-active {
  background: var(--parent-primary);
  color: var(--parent-surface);
}

.pt-custom-inline {
  min-width: 98rpx;
  width: 140rpx;
  text-align: center;
}

.pt-edit-icon {
  width: 28rpx;
  height: 28rpx;
}

.pt-custom-trigger {
  align-items: center;
  justify-content: center;
}

.freq-row {
  display: flex;
  gap: 14rpx;
}

.freq-item {
  flex: 1 1 0;
  text-align: center;
  border-radius: 16rpx;
  background: var(--parent-surface-muted);
  padding: 18rpx 0;
  font-size: 30rpx;
  color: var(--parent-text-secondary);
  font-weight: 600;
}

.freq-active {
  background: var(--parent-primary);
  color: var(--parent-surface);
}

.loop-mode-row {
  margin-top: 14rpx;
  display: flex;
  gap: 14rpx;
}

.mini-item {
  flex: 1 1 0;
  text-align: center;
  border-radius: 14rpx;
  background: var(--parent-surface-muted);
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #4f5a65;
  font-weight: 600;
}

.mini-active {
  background: var(--parent-primary);
  color: var(--parent-surface);
}

.weekday-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.weekday-item {
  text-align: center;
  border-radius: 12rpx;
  background: var(--parent-surface-muted);
  padding: 12rpx 0;
  font-size: 24rpx;
  color: #4f5a65;
  font-weight: 600;
}

.weekday-active {
  background: var(--parent-primary);
  color: var(--parent-surface);
}

.advanced-toggle {
  margin-top: 22rpx;
  border-radius: 18rpx;
  background: #e7f0f5;
  color: var(--parent-primary);
  height: 76rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  font-weight: 700;
}

.advanced-toggle-icon {
  width: 26rpx;
  height: 26rpx;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
}

.advanced-toggle-icon-open {
  transform: rotate(270deg);
}

.advanced-section {
  margin-top: 8rpx;
}

.limit-row {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.limit-label {
  margin-bottom: 0;
  flex: 1;
}

.limit-input {
  width: 180rpx;
  min-width: 180rpx;
  text-align: center;
  font-size: 30rpx;
  padding: 14rpx 16rpx;
}

.tip-card {
  margin-top: 44rpx;
  background: linear-gradient(135deg, var(--parent-primary) 0%, #3ea4d4 100%);
  border-radius: 30rpx;
  padding: 26rpx 24rpx;
  color: var(--parent-surface);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tip-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  flex: 0 0 96rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-content {
  flex: 1;
  min-width: 0;
}

.tip-icon {
  width: 60rpx;
  height: 60rpx;
}

.tip-title {
  display: block;
  font-size: 36rpx;
  line-height: 1.22;
  font-weight: 700;
}

.tip-text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
  opacity: 0.95;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(248, 249, 251, 0.96);
  backdrop-filter: blur(8rpx);
  border-top: 1rpx solid var(--parent-border);
  padding: 18rpx 22rpx calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.btn-cancel,
.btn-save {
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-cancel {
  flex: 1;
  background: var(--parent-surface-muted);
  color: var(--parent-text-secondary);
}

.btn-save {
  flex: 2;
  background: var(--parent-primary);
  color: var(--parent-surface);
  box-shadow: var(--parent-shadow-accent);
}

.is-press {
  transform: scale(var(--parent-press-scale));
  opacity: 0.86;
}
