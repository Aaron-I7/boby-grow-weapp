.container {
  min-height: 100vh;
  background: var(--parent-bg);
}

.nav-shell {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(248, 249, 251, 0.96);
  backdrop-filter: blur(8rpx);
  border-bottom: 1rpx solid var(--parent-border);
}

.nav-inner {
  height: 100%;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 8rpx 12rpx 8rpx 0;
  border-radius: 20rpx;
}

.nav-back {
  width: 34rpx;
  height: 34rpx;
}

.nav-title {
  font-size: 36rpx;
  color: var(--parent-primary-strong);
  font-weight: 800;
}

.nav-avatar {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 2rpx solid #b8dff0;
}

.content {
  padding: 30rpx 0 calc(46rpx + env(safe-area-inset-bottom));
}

.family-card {
  background: linear-gradient(135deg, var(--parent-primary) 0%, #43a8d8 100%);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--parent-shadow-md);
}

.family-main {
  flex: 1;
  min-width: 0;
}

.family-tag {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.86);
  letter-spacing: 1rpx;
  font-weight: 700;
}

.family-name {
  display: block;
  margin-top: 10rpx;
  font-size: 50rpx;
  line-height: 1.16;
  color: var(--parent-surface);
  font-weight: 800;
  word-break: break-all;
}

.family-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  background: rgb(255 255 255 / 20%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 18rpx;
}

.family-icon {
  width: 62rpx;
  height: 62rpx;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  display: block;
  margin: 50rpx 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--parent-text-hint);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.menu-card {
  background: var(--parent-surface);
  border-radius: 45rpx;
  box-shadow: var(--parent-shadow-sm);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 24rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-icon-wrap {
  width: 62rpx;
  height: 62rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex: 0 0 62rpx;
}

.icon-primary-bg {
  background: #e6f2ff;
}

.icon-secondary-bg {
  background: #fff4e5;
}

.icon-neutral-bg {
  background: var(--parent-surface-muted);
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
}

.menu-title {
  font-size: 28rpx;
  color: var(--parent-text);
  font-weight: 700;
  line-height: 1.2;
  margin-left: 20rpx;
}

.menu-text-col {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-sub {
  font-size: 18rpx;
  color: var(--parent-text-hint);
  letter-spacing: 1rpx;
}

.menu-value {
  font-size: 24rpx;
  color: var(--parent-text-hint);
  font-weight: 700;
}

.menu-arrow {
  width: 26rpx;
  height: 26rpx;
  opacity: 0.7;
}

.logout-btn {
  margin-top: 44rpx;
  height: 94rpx;
  border-radius: 26rpx;
  background: #ffe3e3;
  color: #c63535;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.logout-icon {
  width: 28rpx;
  height: 28rpx;
}

.is-press {
  transform: scale(var(--parent-press-scale));
  opacity: 0.86;
}
