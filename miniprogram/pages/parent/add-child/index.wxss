.form-card { margin-top: 24rpx; }
.form-item { margin-bottom: 32rpx; }
.form-label { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 14rpx; color: #26323d; }
.form-input { background: #f3f6f9; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #2b3a45; }

.readonly-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 60rpx;
  border-radius: 30rpx;
  padding: 0 20rpx;
  background: var(--parent-primary-soft);
  color: var(--parent-primary-strong);
  font-size: 26rpx;
  font-weight: 600;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.7;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.mode-switch {
  display: flex;
  align-items: center;
  background: var(--parent-surface-muted);
  border-radius: 26rpx;
  padding: 4rpx;
}

.mode-item {
  min-width: 92rpx;
  text-align: center;
  line-height: 40rpx;
  font-size: 22rpx;
  color: var(--parent-text-hint);
  border-radius: 20rpx;
  padding: 0 10rpx;
}

.mode-active {
  background: var(--parent-surface);
  color: var(--parent-primary-strong);
  font-weight: 600;
}

.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.avatar-cell {
  width: 100rpx;
  height: 100rpx;
  box-sizing: border-box;
  border-radius: 50%;
  padding: 4rpx;
  border: 3rpx solid transparent;
  overflow: hidden;
  background: var(--parent-surface);
}

.avatar-option {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  display: block;
  background: var(--parent-surface);
}

.avatar-selected {
  border-color: var(--parent-primary-strong);
  box-shadow: 0 0 0 4rpx rgba(11, 108, 146, 0.2);
}

.privacy-notice { text-align: center; font-size: 22rpx; color: #98a3ad; padding: 22rpx 0; }

.btn-skip {
  margin-top: 16rpx;
  text-align: center;
  color: var(--parent-text-hint);
  font-size: 24rpx;
  padding: 14rpx 0 10rpx;
}
