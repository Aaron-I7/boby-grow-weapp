<view class="page">
  <view class="panel">
    <view class="logo-wrap">
      <image class="logo" src="/images/svg/ui/icon-home.svg" mode="aspectFit" />
    </view>
    <text class="title">{{labels.title}}</text>
    <text class="subtitle">{{labels.subtitle}}</text>
    <view class="btn-primary login-btn" bindtap="onLoginTap">
      {{loading ? labels.loading : labels.login}}
    </view>
  </view>
</view>
